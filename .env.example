# -------------------------------------------------------------------
# Core URLs ───── fill with YOUR endpoints or leave blank if unused
# -------------------------------------------------------------------
REACT_APP_BASE_URL=https://your-api.example.com          # your backend or proxy root
REACT_APP_RESUME_URL=https://your-site.example.com/resume.pdf
REACT_APP_LINKEDIN_URL=https://linkedin.com/in/your-profile
REACT_APP_CDN_BASE_URL=https://your-cloudfront-id.cloudfront.net/

# -------------------------------------------------------------------
# Firebase (Web SDK v9+) ───── real values live in your local .env
# -------------------------------------------------------------------
REACT_APP_FIREBASE_API_KEY=REPLACE_ME
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=000000000000        # numeric
REACT_APP_FIREBASE_APP_ID=1:000000000000:web:abcdef123456  # format matters
REACT_APP_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX             # optional (Analytics)
GENERATE_SOURCEMAP=false
